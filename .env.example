APP_NAME=GarutVON
FLASK_ENV=production
SECRET_KEY=change-me-with-a-long-random-secret
JWT_SECRET=change-me-with-another-long-random-secret
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require
PUBLIC_BASE_URL=https://garutvon.vercel.app
DOWNLOAD_URL=https://garutvon.vercel.app/download/track
LATEST_VERSION=1.0.0
LATEST_CHECKSUM=sha256:replace-with-release-checksum
DONATION_URL=https://myhappr.com/chisomlifeeugsh
RATE_LIMIT_DEFAULT=200 per day;50 per hour

# Mailjet credentials for password reset email delivery
MAILJET_API_KEY=your-mailjet-api-key
MAILJET_SECRET_KEY=your-mailjet-secret-key
EMAIL_FROM=onboarding@garutvon.app
PASSWORD_RESET_EXPIRY_MINUTES=60
