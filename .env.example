# Local development and production environment variables for GarutVON

# Database
# For local development you can use SQLite:
DATABASE_URL=sqlite:///garutvon.db
# For Neon / PostgreSQL production replace with a real connection string:
# DATABASE_URL=postgresql://<username>:<password>@<host>/<database>?sslmode=require

# Security
SECRET_KEY=replace-with-a-long-secure-random-string
JWT_SECRET=replace-with-a-different-secure-random-string

# Mailjet
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_SECRET_KEY=your_mailjet_secret_key
MAIL_FROM_EMAIL=noreply@garutvon.com
MAIL_FROM_NAME=GarutVON

# Public site URL used by email links and SEO
SITE_URL=https://garutvon.vercel.app

# Development helpers
DEBUG=True
